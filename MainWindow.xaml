<Window x:Class="VRLightGun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VRLightGun"
        mc:Ignorable="d"
        Title="VR Light Gun" Height="500" Width="800"
        Icon="bear.ico">
    <Grid Margin="16">
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Width="350">
            <TextBlock Text="Controller Status" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>
            <TextBlock x:Name="ControllerStatusText" Text="No controllers detected" TextWrapping="Wrap" Margin="0,0,0,12"/>
            
            <TextBlock Text="Controller Mode" FontWeight="Bold" FontSize="18" Margin="0,12,0,12"/>
            <ComboBox x:Name="ControllerModeComboBox" Width="250" HorizontalAlignment="Left" Margin="0,0,0,12">
                <ComboBoxItem Content="Light Gun (Screen Pointing)" IsSelected="True"/>
                <ComboBoxItem Content="Split Xbox Controller Emulation"/>
            </ComboBox>
            <TextBlock x:Name="ModeDescription" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="11" Foreground="Gray" Text="Point controllers at screen to aim. Each controller gets its own virtual Xbox controller."/>
            
            <StackPanel x:Name="SplitModeSettings" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Stick Deadzone" FontSize="11" Margin="0,4,0,2"/>
                <Slider x:Name="StickDeadzoneSlider" Minimum="0" Maximum="0.3" Value="0.1" Width="250" HorizontalAlignment="Left"/>
                <TextBlock x:Name="StickDeadzoneValue" Text="0.10" FontSize="10" Foreground="Gray" Margin="0,0,0,8"/>
                
                <TextBlock Text="Gyro Deadzone" FontSize="11" Margin="0,4,0,2"/>
                <Slider x:Name="GyroDeadzoneSlider" Minimum="0" Maximum="0.2" Value="0.05" Width="250" HorizontalAlignment="Left"/>
                <TextBlock x:Name="GyroDeadzoneValue" Text="0.05" FontSize="10" Foreground="Gray" Margin="0,0,0,8"/>
                
                <TextBlock Text="Right Gyro Sensitivity" FontSize="11" Margin="0,4,0,2"/>
                <Slider x:Name="GyroScaleSlider" Minimum="0.1" Maximum="2.0" Value="0.5" Width="250" HorizontalAlignment="Left"/>
                <TextBlock x:Name="GyroScaleValue" Text="0.50" FontSize="10" Foreground="Gray" Margin="0,0,0,8"/>

                <TextBlock Text="Left Orient Sensitivity" FontSize="11" Margin="0,4,0,2"/>
                <Slider x:Name="LeftOrientScaleSlider" Minimum="0.1" Maximum="4.0" Value="0.5" Width="250" HorizontalAlignment="Left"/>
                <TextBlock x:Name="LeftOrientScaleValue" Text="0.50" FontSize="10" Foreground="Gray"/>
            </StackPanel>
            
            <StackPanel x:Name="CalibrationSection" Margin="0,0,0,0">
                <TextBlock Text="Controller-to-Screen Calibration" FontWeight="Bold" FontSize="18" Margin="0,12,0,12"/>
                <TextBlock x:Name="CalibrationInstructions" Text="Press 'Start Calibration' and follow the on-screen instructions." TextWrapping="Wrap" Margin="0,0,0,12"/>
                <Button x:Name="StartCalibrationButton" Content="Start Calibration" Width="160" Height="32" Click="StartCalibrationButton_Click"/>
            </StackPanel>
            
            <TextBlock Text="Debug Output" FontWeight="Bold" FontSize="14" Margin="0,24,0,8"/>
            <StackPanel x:Name="LeftHandDebugPanel" Orientation="Horizontal" Margin="0,4,0,0" Visibility="Collapsed">
                <TextBlock Text="Left Hand - X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="DebugLeftXBox" Width="60" IsReadOnly="True" Margin="0,0,8,0"/>
                <TextBlock Text="Y:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="DebugLeftYBox" Width="60" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel x:Name="RightHandDebugPanel" Orientation="Horizontal" Margin="0,4,0,0" Visibility="Collapsed">
                <TextBlock Text="Right Hand - X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="DebugXBox" Width="60" IsReadOnly="True" Margin="0,0,8,0"/>
                <TextBlock Text="Y:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="DebugYBox" Width="60" IsReadOnly="True"/>
            </StackPanel>
            
            <TextBlock Text="Axis Debug" FontWeight="Bold" FontSize="14" Margin="0,16,0,8"/>
            <TextBox x:Name="AxisDebugBox" Height="80" IsReadOnly="True" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
    </Grid>
</Window>
